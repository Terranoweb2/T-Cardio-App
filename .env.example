# ============================================
# T-CARDIO PRO - ENVIRONMENT CONFIGURATION
# ============================================

# Server
NODE_ENV=development
PORT=3001

# Database (Prisma)
DATABASE_URL=postgresql://tcardio:tcardio_dev_2024@localhost:5432/tcardio_pro

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=dev_jwt_secret_change_in_production_min_256_bits_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_here
JWT_REFRESH_EXPIRES_IN=7d

# DeepSeek AI
DEEPSEEK_API_KEY=sk-placeholder-replace-with-real-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# MinIO Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=tcardio-reports
MINIO_USE_SSL=false

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006
ENCRYPTION_KEY=dev_encryption_key_32_bytes_long!!

# Feature Flags
ENABLE_AI_ANALYSIS=true
ENABLE_EMERGENCY_ALERTS=true
ENABLE_TELECONSULTATION=true
