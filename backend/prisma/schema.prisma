// ==================== MEDICATION TRACKING ====================

model Medication {
  id            String               @id @default(uuid())
  patientId     String               @map("patient_id")
  name          String
  dosage        String?
  frequency     MedicationFrequency  @default(ONCE_DAILY)
  reminderTimes String[]             @default(["08:00"]) @map("reminder_times")
  startDate     DateTime             @map("start_date") @db.Date
  endDate       DateTime?            @map("end_date") @db.Date
  notes         String?
  isActive      Boolean              @default(true) @map("is_active")
  prescribedBy  String?              @map("prescribed_by")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  patient Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  logs    MedicationLog[]

  @@index([patientId])
  @@map("medications_tracking")
}

model MedicationLog {
  id           String              @id @default(uuid())
  medicationId String              @map("medication_id")
  status       MedicationLogStatus
  scheduledAt  DateTime            @map("scheduled_at")
  takenAt      DateTime?           @map("taken_at")
  notes        String?
  createdAt    DateTime            @default(now()) @map("created_at")

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId, scheduledAt(sort: Desc)])
  @@map("medication_logs")
}

// ==================== APPOINTMENTS ====================

model Appointment {
  id                 String            @id @default(uuid())
  patientId          String            @map("patient_id")
  doctorId           String            @map("doctor_id")
  scheduledAt        DateTime          @map("scheduled_at")
  durationMin        Int               @default(30) @map("duration_min")
  status             AppointmentStatus @default(APPT_PENDING)
  reason             String?
  doctorNote         String?           @map("doctor_note")
  cancelledBy        String?           @map("cancelled_by")
  cancelReason       String?           @map("cancel_reason")
  teleconsultationId String?           @unique @map("teleconsultation_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor           Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  teleconsultation Teleconsultation? @relation(fields: [teleconsultationId], references: [id])

  @@index([patientId])
  @@index([doctorId, scheduledAt])
  @@index([status])
  @@map("appointments")
}

