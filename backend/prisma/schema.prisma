model Payment {
  id                    String        @id @default(uuid())
  patientId             String        @map("patient_id")
  type                  PaymentType
  amountXof             Int           @map("amount_xof")
  status                PaymentStatus @default(PENDING)
  fedapayTransactionId  String?       @unique @map("fedapay_transaction_id")
  fedapayPaymentUrl     String?       @map("fedapay_payment_url")
  fedapayPaymentMethod  String?       @map("fedapay_payment_method")
  fedapayData           Json?         @map("fedapay_data")
  description           String?
  metadata              Json?
  completedAt           DateTime?     @map("completed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  patient            Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  subscriptions      Subscription[]
  creditTransactions CreditTransaction[]

  @@index([patientId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("payments")
}

