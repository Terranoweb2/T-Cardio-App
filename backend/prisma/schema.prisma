// ==================== FAMILY ACCOUNTS ====================

model FamilyGroup {
  id          String   @id @default(uuid())
  name        String
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner       Patient          @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     FamilyMember[]
  invitations FamilyInvitation[]

  @@index([ownerId])
  @@map("family_groups")
}

model FamilyMember {
  id            String     @id @default(uuid())
  familyGroupId String     @map("family_group_id")
  patientId     String     @map("patient_id")
  role          FamilyRole @default(MEMBER)
  addedAt       DateTime   @default(now()) @map("added_at")

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([familyGroupId, patientId])
  @@index([patientId])
  @@map("family_members")
}

model FamilyInvitation {
  id            String                 @id @default(uuid())
  familyGroupId String                 @map("family_group_id")
  invitedEmail  String                 @map("invited_email")
  status        FamilyInvitationStatus @default(FAMILY_PENDING)
  token         String                 @unique
  expiresAt     DateTime               @map("expires_at")
  createdAt     DateTime               @default(now()) @map("created_at")

  familyGroup FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)

  @@index([familyGroupId])
  @@map("family_invitations")
}

